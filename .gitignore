.DS_Store
# Only Project.toml is committed (the dependency contract). Manifest.toml is
# platform/version-pinned (see `julia_version` field) and would break
# cross-machine syncing — each environment resolves its own Manifest from
# Project.toml on first instantiate.
julia-env/Manifest.toml
julia-env/.CondaPkg/
.julia/
.knowledge/literature/**/.raw/
.knowledge/literature/**/.figures/
.knowledge/models/**/.raw/
.knowledge/models/**/.figures/
.knowledge/methods/**/.raw/
.knowledge/methods/**/.figures/
tracks/**/.raw/
tracks/**/.figures/
tracks/**/results/

# Per-method JSON manifests are derived from .knowledge/literature/ref.bib
# via skills/download-ref/helpers/bibtex_to_manifest.py — don't sync.
.knowledge/literature/manifests/

